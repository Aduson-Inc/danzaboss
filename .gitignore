# DANZA system — stack-agnostic .gitignore

# DANZA run logs (local to each user's project, never committed)
.danza/logs/*
!.danza/logs/.gitkeep

# IDE / editor
*.code-workspace
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*
*.pem

# Common build artifacts (added by agents per project)
node_modules/
/build
dist/
/out
__pycache__/
*.pyc
